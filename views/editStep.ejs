<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Step</title>
</head>

<body>
    <!-- NAV -->
    <nav>
        <a href="/">Home</a>
        <a href="/add">Add Task</a>
        <a href="/view">View Tasks</a>
    </nav>

    <h1><%= task.title %> - Edit Step</h1>
    <!-- Show task title and description -->
    <p>
        Description:
        <br>
        <%= task.description %>
    </p>

    <form action="/tasks/<%= taskIndex %>/steps/edit/<%= stepIndex %>" method="POST">
        <!-- Step Title -->
        <div class="form-group">
            <label for="title">Step Title:</label>
            <input type="text" id="title" name="title" value="<%= step.title %>" required>
        </div>

        <!-- Step Note -->
        <div class="form-group">
            <label for="note">Note:</label><br>
            <textarea id="note" name="note" required><%= step.note %></textarea>
        </div>

        <!-- Step Progress -->
        <div class="form-group">
            <label for="progress">Progress:</label>
            <input type="number" id="progress" name="progress" min="0" max="100" value="<%= step.progress %>" required>
        </div>

        <!-- Submit Button -->
        <button type="submit">Save Changes</button>

        <!-- Cancel Button -->
        <button type="button" onclick="window.location.href='/map/<%= taskIndex %>'">Cancel</button>
    </form>
</body>
</html>
